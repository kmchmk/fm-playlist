# ---- Required: Auth0 ----
# Generate with: openssl rand -hex 32
AUTH0_SECRET=

# Your Auth0 tenant domain, e.g. my-tenant.us.auth0.com
AUTH0_DOMAIN=

AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Public URL the app is served at. Use http://localhost:3000 for local dev.
APP_BASE_URL=http://localhost:3000

# ---- Required: Postgres ----
# Used by both the `db` service (to initialize Postgres) and the `app` service
# (DATABASE_URL is constructed from these in docker-compose.yml).
POSTGRES_DB=fm_playlist
POSTGRES_USER=fmplaylist
POSTGRES_PASSWORD=change-me

# ---- Optional: Airtable sync ----
# Leave unset to skip Airtable integration entirely.
AIRTABLE_API_TOKEN=
AIRTABLE_BASE_ID=

# ---- Optional: domain allowlist for Auth0 logins ----
# Defaults to favoritemedium.com if unset.
ALLOWED_EMAIL_DOMAIN=favoritemedium.com
