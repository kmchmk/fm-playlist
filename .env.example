# ---- Required: Clerk ----
# Get these from Clerk Dashboard > Configure > API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- Required: Postgres ----
# Used by both the `db` service (to initialize Postgres) and the `app` service
# (DATABASE_URL is constructed from these in docker-compose.yml).
POSTGRES_DB=fm_playlist
POSTGRES_USER=fmplaylist
POSTGRES_PASSWORD=change-me

# For non-compose local development or managed hosts, set DATABASE_URL instead
# of relying on docker-compose.yml to build it.
# DATABASE_URL=postgres://fmplaylist:change-me@localhost:5432/fm_playlist

# ---- Optional: Airtable sync ----
# Leave unset to skip Airtable integration entirely.
AIRTABLE_API_TOKEN=
AIRTABLE_BASE_ID=

# ---- Optional: domain allowlist for Clerk users ----
# Also configure this in Clerk Dashboard. Defaults to favoritemedium.com if unset.
ALLOWED_EMAIL_DOMAIN=favoritemedium.com
